<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} - whats app web</title>
    <style>
        body { font-family: "Source Serif Pro", serif; background: #fafafa; color: #2d3436; margin: 0; line-height: 1.8; }
        .post-wrapper { max-width: 800px; margin: 60px auto; background: white; padding: 60px; border: 1px solid #eee; }
        h1 { font-size: 2.5rem; color: #075E54; margin-bottom: 10px; }
        .meta { color: #b2bec3; font-style: italic; margin-bottom: 40px; border-bottom: 1px solid #eee; padding-bottom: 20px; }
        .content h2 { color: #128C7E; margin-top: 40px; font-family: sans-serif; }
        .nav-links { display: flex; justify-content: space-between; margin-top: 80px; padding-top: 20px; border-top: 1px solid #eee; font-family: sans-serif; }
        .nav-links a { color: #128C7E; text-decoration: none; font-weight: 600; }
        footer { text-align: center; padding: 40px; color: #636e72; font-size: 0.9rem; }
    </style>
</head>
<body>
    <article class="post-wrapper">
        <header>
            <h1>{{ title }}</h1>
            <div class="meta">发布于: {{ date | dateFilter }} | 分类: 技术指引</div>
        </header>
        <div class="content">
            {{ content | safe }}
        </div>
        <nav class="nav-links">
            {% if prevPost %}<a href="{{ prevPost.url }}">← 上一篇: {{ prevPost.data.title }}</a>{% else %}<span></span>{% endif %}
            {% if nextPost %}<a href="{{ nextPost.url }}">下一篇: {{ nextPost.data.title }} →</a>{% endif %}
        </nav>
    </article>
    <footer>
        <p><a href="/" style="color:#636e72">返回首页</a> | 隐私政策 | 联系我们</p>
        <p>RDQJM.COM - whats app web</p>
    </footer>
</body>
</html>
    